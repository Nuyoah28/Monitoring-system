VUE_APP_DIGITAL_HUMAN_MODE=live2d

# Live2D settings
VUE_APP_LIVE2D_MODEL_URL=https://cdn.jsdelivr.net/gh/guansss/pixi-live2d-display@0.4.0/test/assets/haru/haru_greeter_t03.model3.json
VUE_APP_LIVE2D_CUBISM_VERSION=4
VUE_APP_LIVE2D_CUBISM_CORE_URL=https://cubism.live2d.com/sdk-web/cubismcore/live2dcubismcore.min.js
VUE_APP_LIVE2D_FIT_SCALE=0.82
VUE_APP_LIVE2D_POSITION_X=0
VUE_APP_LIVE2D_POSITION_Y=0.08
VUE_APP_LIVE2D_IDLE_MOTION=Idle
VUE_APP_LIVE2D_LISTENING_MOTION=Idle
VUE_APP_LIVE2D_SPEAKING_MOTION=Tap
VUE_APP_LIVE2D_TAP_MOTION=Tap

# Video digital human settings
# Set VUE_APP_DIGITAL_HUMAN_MODE=video to enable.
# Recommended: prepare three clips for idle / listening / speaking states.
VUE_APP_DIGITAL_HUMAN_VIDEO_IDLE=
VUE_APP_DIGITAL_HUMAN_VIDEO_LISTENING=
VUE_APP_DIGITAL_HUMAN_VIDEO_SPEAKING=
VUE_APP_DIGITAL_HUMAN_VIDEO_POSTER=
