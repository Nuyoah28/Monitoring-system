{
	"easycom": {
		"^u-(.*)": "uview-ui/components/u-$1/u-$1.vue"
	},
	"pages": [
		{
			"path": "pages/sys/start/start",
			"style": {
				"navigationBarTitleText": "",
				"enablePullDownRefresh": false,
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/sys/login/index",
			"style": {
				"navigationBarTitleText": "登录",
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/sys/realtime/realtime",
			"style": {
				"navigationBarTitleText": "",
				"enablePullDownRefresh": false,
				"navigationStyle": "custom",
				"app-plus": {
					"bounce": "none"
				}
			}
		},
		{
			"path": "pages/sys/dateWatcher/dateWatcher",
			"style": {
				"navigationBarTitleText": "",
				"enablePullDownRefresh": false,
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/sys/home/home",
			"style": {
				"navigationBarTitleText": "",
				"enablePullDownRefresh": false,
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/sys/controls/controls",
			"style": {
				"navigationBarTitleText": "",
				"enablePullDownRefresh": false,
				"navigationStyle": "custom",
				"app-plus": {
					"bounce": "none"
				}
			}
		},
		{
			"path": "pages/sys/personal/personal",
			"style": {
				"navigationBarTitleText": "",
				"enablePullDownRefresh": false,
				"navigationStyle": "custom",
				"app-plus": {
					"bounce": "none"
				}
			}
		},
		{
			"path": "pages/sys/personal/setting/setting",
			"style": {
				"navigationBarTitleText": "",
				"enablePullDownRefresh": false,
				"navigationStyle": "custom",
				"app-plus": {
					"bounce": "none"
				}
			}
		},
		{
			"path": "pages/sys/personal/edit/edit",
			"style": {
				"navigationBarTitleText": "",
				"enablePullDownRefresh": false,
				"navigationStyle": "custom",
				"app-plus": {
					"bounce": "none"
				}
			}
		},
		{
			"path": "components/UnityModelViewer",
			"style": {
				"navigationBarTitleText": "",
				"enablePullDownRefresh": false
			}
		}
	],
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "uni-app",
		"navigationBarBackgroundColor": "#F8F8F8",
		"backgroundColor": "#F8F8F8"
	},
	"uniIdRouter": {},
	"tabBar": {
	  "color": "#6A7990",
	  "selectedColor": "#007AFF",
	  "backgroundColor": "#EBF5FF",
	  "borderStyle": "white",
	  "height": "56px", // 固定tabBar高度，给文字留空间（建议50-60px）
	  "iconWidth": "20px", // 缩小图标宽度（原24无单位，需加px）
	  "fontSize": "10px", // 文字大小
	  "spacing": "2px", // 图标与文字间距
	  "list": [
	    {
	      "pagePath": "pages/sys/realtime/realtime",
	      "text": "警报信息", // 必须保留text字段
	      "iconPath": "static/tabBar/realTime.png",
	      "selectedIconPath": "static/chosenTabBar/realtime.png"
	    },
	    {
	      "pagePath": "pages/sys/controls/controls",
	      "text": "设备控制",
	      "iconPath": "static/tabBar/contorl.png",
	      "selectedIconPath": "static/chosenTabBar/control.png"
	    },
	    {
	      "pagePath": "pages/sys/dateWatcher/dateWatcher",
	      "text": "数据统计",
	      "iconPath": "static/tabBar/chart.png",
	      "selectedIconPath": "static/chosenTabBar/chart.png"
	    },
	    {
	      "pagePath": "pages/sys/home/home",
	      "text": "智能分析",
	      "iconPath": "static/tabBar/GPT.png",
	      "selectedIconPath": "static/chosenTabBar/GPT.png"
	    },
	    {
	      "pagePath": "pages/sys/personal/personal",
	      "text": "个人中心",
	      "iconPath": "static/tabBar/personal.png",
	      "selectedIconPath": "static/chosenTabBar/personal.png"
	    }
	  ]
	}
}