{
  "camera_id": "gate_01",
  "source": "",
  "model_path": "../models/carflow.pt",
  "tracker_path": "../yolov13/ultralytics/cfg/trackers/bytetrack.yaml",
  "conf": 0.25,
  "iou": 0.5,
  "imgsz": 640,
  "device": "cpu",
  "max_det": 200,
  "half": false,
  "verbose": false,
  "report_interval_seconds": 5,
  "output_jsonl": "../outputs/flow_events.jsonl",
  "http_report": {
    "url": "",
    "headers": {},
    "timeout_seconds": 5
  },
  "rules": {
    "max_track_history": 30,
    "stale_frames": 90,
    "lines": [
      {
        "id": "entry_line",
        "points": [[220, 420], [980, 420]],
        "direction_hint": "down_is_in"
      }
    ],
    "regions": [
      {
        "id": "waiting_area",
        "points": [[180, 350], [1040, 350], [1080, 520], [140, 520]],
        "mode": "occupancy"
      },
      {
        "id": "entry_zone",
        "points": [[260, 300], [960, 300], [1010, 430], [210, 430]],
        "mode": "enter_exit"
      }
    ]
  }
}
